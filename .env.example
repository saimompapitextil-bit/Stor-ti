# Supabase → Project Settings → Database
# "Connection string" → URI (modo Transaction ou Session conforme o painel)

# Recomendado para a app (Pooler / Transaction mode — porta 6543 no host pooler.supabase.com)
# Inclua ?pgbouncer=true e limite de conexões para serverless/Next.js
DATABASE_URL="postgresql://postgres.PROJECT_REF:SUA_SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Conexão direta (porta 5432) — obrigatória para prisma migrate / db push (schema)
# Use o host db.PROJECT_REF.supabase.co ou Session pooler conforme a documentação do seu projeto
DIRECT_URL="postgresql://postgres:SUA_SENHA@db.PROJECT_REF.supabase.co:5432/postgres"
