# Supabase → Project Settings → Database → Connection string → URI
#
# Caminho mais simples com Prisma: use "Direct connection" (host db.xxx.supabase.co, porta 5432).
# Acrescente sslmode=require se a string do painel não incluir:
#
# DATABASE_URL="postgresql://postgres:SUA_SENHA@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
#
# Pooler Transaction (6543) no serverless: possível com ?pgbouncer=true&connection_limit=1;
# para prisma db push use a mesma URI Direct localmente ou rode push antes do deploy.

DATABASE_URL="postgresql://postgres:SUA_SENHA@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
